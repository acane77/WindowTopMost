<Window x:Class="MelinaWindowTopmost.InformationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Icon="Assets/maki5.ico"
        Width="520"
        Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Microsoft YaHei"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer>
            <StackPanel>
                <TextBlock Text="{Binding Header}" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" />
                <TextBlock Text="{Binding Subtitle}" Margin="0,6,0,20" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                <TextBlock Text="{Binding HandleLabel}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Handle}" Margin="0,4,0,14" TextWrapping="Wrap" />

                <TextBlock Text="{Binding TitleLabel}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding WindowTitle}" Margin="0,4,0,14" TextWrapping="Wrap" />

                <TextBlock Text="{Binding ProcessLabel}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Process}" Margin="0,4,0,14" TextWrapping="Wrap" />

                <TextBlock Text="{Binding PathLabel}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Path}" Margin="0,4,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="1"
                Content="{Binding CloseText}"
                MinWidth="88"
                HorizontalAlignment="Right"
                Margin="0,18,0,0"
                Click="CloseButton_Click" />
    </Grid>
</Window>
