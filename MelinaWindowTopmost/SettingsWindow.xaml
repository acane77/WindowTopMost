<Window x:Class="MelinaWindowTopmost.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{Binding Path=Localization[Settings]}"
        Icon="Assets/maki5.ico"
        Width="520"
        Height="510"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        FontFamily="Microsoft YaHei"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Path=Localization[Settings]}"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,18" />

        <StackPanel Grid.Row="1">
            <TextBlock Text="{Binding Path=Localization[Language]}" FontWeight="SemiBold" />
            <ComboBox x:Name="LanguageCombo"
                      Margin="0,6,0,18"
                      SelectedValue="{Binding Settings.Language}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Content="{Binding Path=Localization[System]}" Tag="System" />
                <ComboBoxItem Content="简体中文" Tag="ZhHans" />
                <ComboBoxItem Content="繁體中文" Tag="ZhHant" />
                <ComboBoxItem Content="日本語" Tag="Ja" />
                <ComboBoxItem Content="English" Tag="En" />
            </ComboBox>

            <TextBlock Text="{Binding Path=Localization[Theme]}" FontWeight="SemiBold" />
            <ComboBox Margin="0,6,0,18"
                      SelectedValue="{Binding Settings.Theme}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Content="{Binding Path=Localization[System]}" Tag="System" />
                <ComboBoxItem Content="{Binding Path=Localization[Light]}" Tag="Light" />
                <ComboBoxItem Content="{Binding Path=Localization[Dark]}" Tag="Dark" />
            </ComboBox>

            <TextBlock Text="{Binding Path=Localization[Backdrop]}" FontWeight="SemiBold" />
            <ComboBox Margin="0,6,0,18"
                      SelectedValue="{Binding Settings.Backdrop}"
                      SelectedValuePath="Tag">
                <ComboBoxItem Content="{Binding Path=Localization[BackdropNone]}" Tag="None" />
                <ComboBoxItem x:Name="MicaBackdropItem" Content="Mica" Tag="Mica" />
                <ComboBoxItem Content="{Binding AcrylicBackdropText}" Tag="Acrylic" />
                <ComboBoxItem x:Name="TabbedBackdropItem" Content="Tabbed" Tag="Tabbed" />
            </ComboBox>

            <CheckBox Content="{Binding Path=Localization[AutoRefresh]}"
                      IsChecked="{Binding Settings.AutoRefresh}"
                      Margin="0,0,0,14" />

            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Path=Localization[Interval]}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <ui:NumberBox Grid.Column="1"
                              Width="236"
                              Margin="16,0,4,0"
                              Minimum="0.5"
                              Maximum="10"
                              SmallChange="0.5"
                              Value="{Binding Settings.RefreshIntervalSeconds}" />
                <TextBlock Text="{Binding Path=Localization[Seconds]}"
                           Grid.Column="2"
                           VerticalAlignment="Center" />
            </Grid>

            <Button Content="{Binding Path=Localization[ClearIconCache]}"
                    HorizontalAlignment="Left"
                    Command="{Binding ClearIconCacheCommand}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding Path=Localization[Close]}"
                    MinWidth="88"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click" />
            <Button Content="{Binding Path=Localization[Save]}"
                    MinWidth="88"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
