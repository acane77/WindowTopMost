<Window x:Class="MelinaWindowTopmost.OpacityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding TitleText}"
        Icon="Assets/maki5.ico"
        Width="720"
        Height="250"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Microsoft YaHei"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding HeaderText}"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="96" />
            </Grid.ColumnDefinitions>

            <Slider x:Name="OpacitySlider"
                    Grid.Column="0"
                    Minimum="0"
                    Maximum="100"
                    TickFrequency="10"
                    IsSnapToTickEnabled="False"
                    Value="{Binding OpacityPercent, UpdateSourceTrigger=PropertyChanged}"
                    VerticalAlignment="Center" />

            <TextBox Grid.Column="2"
                     Height="32"
                     VerticalContentAlignment="Center"
                     Text="{Binding OpacityText, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,6,114,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="0%" FontSize="16" />
            <TextBlock Grid.Column="2" Text="100%" FontSize="16" />
        </Grid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,24,0,0">
            <Button Content="{Binding OkText}"
                    MinWidth="130"
                    Margin="0,0,12,0"
                    Click="OkButton_Click" />
            <Button Content="{Binding CancelText}"
                    MinWidth="130"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
